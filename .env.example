# Stripe API Keys
# Retrieve these from your Stripe Dashboard (Developers > API Keys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Webhook Secret (retrieve via Stripe CLI or dashboard webhook settings)
STRIPE_WEBHOOK_SECRET=

# Stripe Billing Meter ID (Generated by running `pnpm tsx scripts/create-stripe-products.ts`)
STRIPE_LEAD_METER_ID=

# Pricing Tier Price IDs (Generated by running `pnpm tsx scripts/create-stripe-products.ts`)
STRIPE_BUSINESS_MONTHLY_PRICE_ID=
STRIPE_BUSINESS_SETUP_PRICE_ID=
STRIPE_BUSINESS_LEAD_PRICE_ID=

STRIPE_SCALE_MONTHLY_PRICE_ID=
STRIPE_SCALE_SETUP_PRICE_ID=
STRIPE_SCALE_LEAD_PRICE_ID=

# Application configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
